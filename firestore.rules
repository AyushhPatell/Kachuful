rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /sessions/{sessionCode} {
      allow read, write: if request.auth != null;

      match /players/{playerId} {
        allow read, write: if request.auth != null;
      }

      match /rounds/{roundId} {
        allow read, write: if request.auth != null;
      }

      match /joinRequests/{requestId} {
        allow read, write: if request.auth != null;
      }
    }

    // Session history — each player can only read their own history.
    // Any authenticated player can write (the game engine writes all players' summaries at round end).
    match /userHistory/{userId}/sessions/{sessionCode} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null;
    }
  }
}
