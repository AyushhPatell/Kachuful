rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /sessions/{sessionCode} {
      allow read, write: if request.auth != null;

      match /players/{playerId} {
        allow read, write: if request.auth != null;
      }

      match /rounds/{roundId} {
        allow read, write: if request.auth != null;
      }

      match /joinRequests/{requestId} {
        allow read, write: if request.auth != null;
      }
    }

    // Session history. Any authenticated player can read/write any entry —
    // the game engine writes every participant's summary at session end, and
    // the storage-cleanup sweep needs to check whether a session has scrolled
    // out of every participant's recent-history view before deleting it.
    match /userHistory/{userId}/sessions/{sessionCode} {
      allow read, write: if request.auth != null;
    }
  }
}
